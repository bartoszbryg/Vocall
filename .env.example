# Application
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
SECRET_KEY=change-me-in-production

# Anthropic / Claude
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (fallback / embeddings)
OPENAI_API_KEY=sk-...

# Deepgram (speech-to-text)
DEEPGRAM_API_KEY=...

# ElevenLabs (text-to-speech)
ELEVENLABS_API_KEY=...

# Database
DATABASE_URL=postgresql+asyncpg://saga:saga@localhost:5432/saga

# Redis (session / pub-sub)
REDIS_URL=redis://localhost:6379/0

# Graph
GNN_MODEL_PATH=./models/gnn_checkpoint.pt
TEMPORAL_WINDOW_SECONDS=3600
MAX_GRAPH_NODES=10000

# Voice
VOICE_SAMPLE_RATE=16000
VOICE_CHUNK_DURATION_MS=500
